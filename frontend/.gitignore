# ==========================================
# SynapseRFP — Final Master .gitignore
# ==========================================

# 1. Environment & Secrets (CRITICAL)
# ------------------------------------------
.env
.env.local
.env.*.local
frontend/.env*
*.pem

# 2. Python & Backend (FastAPI, LangChain)
# ------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
env/
backend/ingestion/data/*
!backend/ingestion/data/.gitkeep
*.db
*.sqlite3

# 3. Next.js & Frontend (React, Node)
# ------------------------------------------
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.swc/
frontend/coverage/
frontend/.vercel/

# Plug'n'Play & Yarn
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# TypeScript & Next build cache
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 4. OS & IDE Specific
# ------------------------------------------
.DS_Store
.vscode/
.idea/
*.swp